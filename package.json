{
  "name": "uplinea",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-clerk-convex-auth-env.mjs",
    "dev": "next dev --webpack",
    "predev:auth-local": "node scripts/check-clerk-convex-auth-env.mjs",
    "dev:auth-local": "UPLINEA_DISABLE_AUTH=0 NEXT_PUBLIC_UPLINEA_DISABLE_AUTH=0 next dev --webpack -H 0.0.0.0 -p 3002",
    "dev:coach": "next dev --webpack -H 0.0.0.0 -p 3100",
    "dev:smoke": "UPLINEA_DISABLE_AUTH=1 NEXT_PUBLIC_UPLINEA_DISABLE_AUTH=1 next dev --webpack -H localhost -p ${SMOKE_PORT:-3103}",
    "dev:coach:bg": "bash scripts/coach-dev.sh start",
    "dev:coach:restart": "bash scripts/coach-dev.sh restart",
    "dev:coach:status": "bash scripts/coach-dev.sh status",
    "dev:coach:stop": "bash scripts/coach-dev.sh stop",
    "convex:dev": "convex dev",
    "convex:codegen": "convex codegen --typecheck enable",
    "convex:typecheck": "tsc -p convex/tsconfig.json --noEmit",
    "check:auth-env": "node scripts/check-clerk-convex-auth-env.mjs",
    "build": "next build --webpack",
    "start:coach": "next start -H 0.0.0.0 -p 3100",
    "start": "next start",
    "lint": "eslint",
    "smoke:coach": "node scripts/smoke-coach-flow.mjs",
    "smoke:coach:auth": "node scripts/smoke-authenticated-coach-flow.mjs",
    "smoke:mvp:auth": "node scripts/smoke-authenticated-mvp-flow.mjs",
    "smoke:study:auth": "node scripts/smoke-authenticated-study-flow.mjs",
    "smoke:empty:auth": "node scripts/smoke-authenticated-empty-state.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.9",
    "convex": "^1.37.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
